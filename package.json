{
  "name": "@fastlabai/design-editor",
  "version": "1.0.0-beta.4",
  "description": "Open-source image design editor for React and Next.js",
  "license": "MIT",
  "author": "fastlab.ai",
  "keywords": [
    "react",
    "nextjs",
    "design",
    "editor",
    "image-editor",
    "canvas",
    "fabricjs",
    "fastlabai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fastlabai/design-editor.git"
  },
  "homepage": "https://fastlab.ai",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup && tailwindcss -i src/theme/theme.css -o dist/theme.css && node scripts/postbuild-use-client.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "size": "size-limit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@imgly/background-removal": {
      "optional": true
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "antd": "^5.29.3",
    "clsx": "^2.1.1",
    "fabric": "^5.5.2",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/fabric": "^5.3.11",
    "@types/lodash": "^4.17.24",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^29.1.1",
    "lodash": "^4.18.1",
    "postcss": "^8.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resize-observer-polyfill": "^1.5.1",
    "size-limit": "^11.1.6",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
