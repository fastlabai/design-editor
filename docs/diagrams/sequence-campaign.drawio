  <diagram id="seq-campaign" name="Campaign Lifecycle Sequence">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="instructions" value="&lt;b&gt;HOW TO RENDER THIS DIAGRAM IN DRAW.IO&lt;/b&gt;&lt;br/&gt;1. Open this file in diagrams.net (app.diagrams.net)&lt;br/&gt;2. Click &lt;b&gt;Extras &amp;gt; Edit Diagram&lt;/b&gt;&lt;br/&gt;3. In the dialog, click the &lt;b&gt;Mermaid&lt;/b&gt; tab&lt;br/&gt;4. Paste the code from &lt;b&gt;sequence-campaign.md&lt;/b&gt; (the mermaid code block, without the backticks)&lt;br/&gt;5. Click &lt;b&gt;OK&lt;/b&gt; — Draw.io will convert it to native editable shapes&lt;br/&gt;&lt;br/&gt;Or edit directly in &lt;b&gt;sequence-campaign.md&lt;/b&gt; which renders in GitHub, Notion, and mermaid.live" style="text;html=1;strokeColor=#1565c0;fillColor=#e3f2fd;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;spacingLeft=10;spacingTop=10;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="780" height="160" as="geometry" />
        </mxCell>

        <mxCell id="seqtitle" value="AdSpot — Campaign Lifecycle Sequence" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="20" width="340" height="44" as="geometry" />
        </mxCell>

        <mxCell id="summary" value="&lt;b&gt;Flows covered:&lt;/b&gt;&lt;br/&gt;① Media Upload (multipart → Multer → DB PENDING)&lt;br/&gt;② Admin Approval (review → APPROVED → notification)&lt;br/&gt;③ Campaign Creation (screen search → budget check → CampaignScreens M:N)&lt;br/&gt;④ Activation &amp; Charging (Bull job → per-play deduction → publisher credit)&lt;br/&gt;⑤ TV Delivery (campaign feed → media serve → rotation)&lt;br/&gt;⑥ Analytics Reporting (aggregate views → spend breakdown)" style="text;html=1;strokeColor=#00695c;fillColor=#e0f2f1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;spacingLeft=10;spacingTop=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="80" width="340" height="130" as="geometry" />
        </mxCell>

        <mxCell id="sep" value="" style="line;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="200" width="1160" height="10" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
